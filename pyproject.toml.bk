[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "pancake-mcp-server"
version = "0.1.0"
description = "Remote MCP server integrating Claude with Pancake POS API"
requires-python = ">=3.10"
dependencies = [
    "fastmcp>=2.3.0",
    "httpx>=0.27.0",
    "uvicorn[standard]>=0.30.0",
    "pydantic>=2.7.0",
    "python-dotenv>=1.0.0",
    "aiohttp>=3.8.0",
    "Pillow>=10.0.0",
    "opencv-python-headless>=4.8.0.0",
    "pytesseract>=0.3.10",
    "easyocr>=1.7.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0.0",
    "pytest-asyncio>=0.23.0",
    "respx>=0.21.0",
    "pytest-httpx>=0.30.0",
]

[tool.hatch.metadata]
allow-direct-references = true

[tool.hatch.build.targets.wheel]
packages = ["src/pancake_mcp"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]

[project.scripts]
pancake-mcp       = "pancake_mcp.server:main"
pancake-mcp-stdio = "pancake_mcp.server:main_stdio"
