# Pancake MCP Server Configuration

# Host and port for the MCP server
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Optional: Set a fixed API key for single-tenant deployments
# If set, this key is used instead of the Bearer token from the request
# Leave empty for multi-tenant mode (Claude passes key as Bearer token)
PANCAKE_API_KEY=

# Optional: Pancake Chat/Inbox API token (pages.fm conversations & messages)
# Falls back to PANCAKE_API_KEY if not set (same key often works for both)
PANCAKE_ACCESS_TOKEN=

# Pancake API base URLs (rarely need changing)
PANCAKE_API_BASE_URL=https://pos.pages.fm/api/v1
PANCAKE_CHAT_BASE_URL=https://pages.fm/api/v1
